---
import '../styles/global.css';
const { title, activePage = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title} — matteo dada</title>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <a href="/" class="site-name">matteo dada</a>
      <nav>
        <a href="/observations" class:list={[{ active: activePage === 'observations' }]}>observations</a>
        <a href="/adventures" class:list={[{ active: activePage === 'adventures' }]}>adventures</a>
        <a href="/projects" class:list={[{ active: activePage === 'projects' }]}>projects</a>
        <a href="/creatives" class:list={[{ active: activePage === 'creatives' }]}>creatives</a>
        <a href="/curation" class:list={[{ active: activePage === 'curation' }]}>curation</a>
      </nav>
    </aside>
    <main class="content">
      <slot />
    </main>
  </div>
</body>
</html>
